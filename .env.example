# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Public site URL for OAuth redirects (production: https://orin.chat)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — never expose to the browser
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_SPEECH_ENGINE_ID=your-speech-engine-id

# Voice sidecar public WebSocket URL (ngrok/cloudflared in dev, Railway/Fly in prod)
VOICE_SERVER_PUBLIC_URL=wss://your-voice-server.example.com/ws
VOICE_SERVER_PORT=3001
VOICE_SERVER_PATH=/ws

# Encrypt user BYOK API keys at rest (32+ characters)
API_KEY_ENCRYPTION_SECRET=your-32-char-minimum-encryption-secret
